{
  "name": "czap",
  "version": "0.10.0",
  "private": true,
  "description": "Constraint-based adaptive rendering framework — monorepo root",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc --build packages/error packages/gauntlet packages/canonical packages/genui packages/core packages/quantizer packages/compiler packages/web packages/detect packages/edge packages/worker packages/vite packages/astro packages/stage packages/cloudflare packages/remotion packages/scene packages/assets packages/audit packages/command packages/cli packages/mcp-server packages/liteship packages/create-liteship",
    "build:wasm": "pnpm exec tsx scripts/build-wasm.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm run typecheck:scripts && pnpm run typecheck:tests",
    "typecheck:scripts": "tsc --project tsconfig.scripts.json",
    "typecheck:tests": "tsc --project tsconfig.tests.json",
    "typecheck:spine": "tsc --noEmit --project packages/_spine/tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:shard": "tsx scripts/test-shard.ts",
    "test:unit": "vitest run --config vitest.config.ts tests/unit/",
    "test:smoke": "vitest run --config vitest.config.ts tests/smoke/",
    "test:property": "vitest run --config vitest.config.ts tests/property/",
    "test:component": "vitest run --config vitest.config.ts tests/component/",
    "test:integration": "vitest run --config vitest.config.ts tests/integration/",
    "test:regression": "vitest run --config vitest.config.ts tests/regression/",
    "test:redteam": "vitest run --config vitest.config.ts tests/regression/red-team-runtime.test.ts",
    "coverage": "pnpm run coverage:merge",
    "coverage:node": "vitest run --config vitest.config.ts --coverage",
    "coverage:node:tracked": "cross-env NODE_V8_COVERAGE=coverage/subprocess-raw vitest run --config vitest.config.ts --coverage",
    "coverage:browser": "vitest run --config vitest.browser.config.ts --coverage",
    "coverage:merge": "rimraf coverage/subprocess-raw && pnpm run coverage:node:tracked && pnpm run coverage:browser && tsx scripts/merge-subprocess-v8.ts && tsx scripts/merge-coverage.ts",
    "coverage:merge-shards": "tsx scripts/merge-shard-coverage.ts",
    "report:runtime-seams": "pnpm exec tsx scripts/report-runtime-seams.ts",
    "report:satellite-scan": "pnpm exec tsx scripts/report-satellite-scan.ts",
    "feedback:verify": "pnpm exec tsx scripts/feedback-verify.ts",
    "runtime:gate": "pnpm exec tsx scripts/runtime-gate.ts",
    "standards:gate": "pnpm exec tsx scripts/standards-integrity-gate.ts",
    "capability:gate": "pnpm exec tsx scripts/capability-gate.ts",
    "plumb:gate": "pnpm exec tsx packages/cli/src/bin.ts plumb",
    "flex:verify": "pnpm exec tsx scripts/flex-verify.ts",
    "devx:check": "pnpm exec tsx scripts/devx-check.ts",
    "audit": "pnpm run audit:report",
    "audit:structure": "pnpm exec tsx scripts/audit/structure.ts",
    "audit:integrity": "pnpm exec tsx scripts/audit/integrity.ts",
    "audit:surface": "pnpm exec tsx scripts/audit/surface.ts",
    "audit:report": "pnpm exec tsx scripts/audit/report.ts",
    "audit:floor": "pnpm exec tsx packages/cli/src/bin.ts audit-floor",
    "coverage:unit": "vitest run --config vitest.config.ts --coverage tests/unit/",
    "coverage:smoke": "vitest run --config vitest.config.ts --coverage tests/smoke/",
    "bench:gate": "pnpm run build && tsx scripts/bench-gate.ts",
    "bench:alloc": "pnpm run build && node --expose-gc --import tsx scripts/alloc-gate.ts",
    "bench:trend": "tsx scripts/bench-trend.ts",
    "bench:reality": "pnpm run build && tsx scripts/bench-reality.ts",
    "bench": "pnpm run build && tsx tests/bench/core.bench.ts && tsx tests/bench/compiler.bench.ts && tsx tests/bench/video.bench.ts && tsx tests/bench/self-measure.bench.ts && tsx tests/bench/directive.bench.ts && tsx tests/bench/ecs-composition.bench.ts && tsx tests/bench/wasm-compute.bench.ts",
    "capsule:compile": "pnpm exec tsx scripts/capsule-compile.ts",
    "capsule:verify": "pnpm exec tsx packages/cli/src/bin.ts capsule-verify",
    "check": "pnpm run lint && pnpm run typecheck",
    "check:gates": "pnpm exec tsx packages/cli/src/bin.ts check",
    "test:e2e": "pnpm exec playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:stress": "pnpm exec playwright test --config tests/e2e/playwright.config.ts tests/e2e/capture.e2e.ts --workers 1 --repeat-each 10",
    "test:e2e:stream-stress": "pnpm exec playwright test --config tests/e2e/playwright.config.ts tests/e2e/stream.e2e.ts --workers 1 --repeat-each 10",
    "test:flake": "pnpm exec tsx scripts/test-flake.ts",
    "test:astro": "pnpm exec tsx scripts/test-astro.ts",
    "test:cloudflare": "pnpm exec tsx scripts/test-cloudflare-astro.ts",
    "test:cloudflare-dev": "pnpm exec tsx scripts/test-cloudflare-dev.ts",
    "test:vite": "pnpm exec tsx scripts/test-vite.ts",
    "test:tailwind": "pnpm exec tsx scripts/test-tailwind.ts",
    "package:smoke": "pnpm run build && pnpm exec tsx packages/cli/src/bin.ts package-smoke",
    "release:notes": "pnpm exec tsx scripts/extract-changelog-section.ts",
    "ship": "node packages/cli/bin/czap.mjs ship",
    "verify": "node packages/cli/bin/czap.mjs verify",
    "gauntlet:full": "tsx scripts/gauntlet.ts",
    "demo:remotion": "pnpm run --filter remotion-demo render",
    "docs:build": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" pnpm exec typedoc",
    "docs:build:sharded": "pnpm exec tsx scripts/build-api-docs.ts",
    "docs:bundle": "pnpm exec tsx scripts/docs-bundle.ts",
    "docs:check": "pnpm exec tsx scripts/docs-check.ts",
    "docs:gen": "pnpm exec tsx scripts/gen-docs.ts",
    "lint": "eslint --max-warnings 0 \"packages/*/src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:structural": "ast-grep scan -c sgconfig.yml packages tests scripts vitest.config.ts vitest.browser.config.ts vitest.shared.ts",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "fix": "pnpm run format && pnpm run lint --fix",
    "cover": "pnpm run coverage",
    "shakedown": "pnpm exec tsx scripts/setup.ts",
    "doctor": "pnpm exec tsx scripts/doctor.ts",
    "dev": "vitest --config vitest.config.ts",
    "clean": "pnpm exec tsx scripts/clean.ts",
    "scripts": "pnpm exec tsx scripts/scripts-index.ts",
    "glossary": "pnpm exec tsx scripts/glossary.ts",
    "prepare": "pnpm exec tsx scripts/link-pre-commit.ts",
    "postinstall": "pnpm exec tsx scripts/postinstall.ts"
  },
  "devDependencies": {
    "@czap/astro": "workspace:*",
    "@czap/audit": "workspace:*",
    "@czap/error": "workspace:*",
    "@czap/compiler": "workspace:*",
    "@czap/core": "workspace:*",
    "@czap/detect": "workspace:*",
    "@czap/edge": "workspace:*",
    "@czap/quantizer": "workspace:*",
    "@czap/remotion": "workspace:*",
    "@czap/stage": "workspace:*",
    "@czap/vite": "workspace:*",
    "@czap/web": "workspace:*",
    "@czap/worker": "workspace:*",
    "@ast-grep/cli": "^0.44.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/node": "4",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "cborg": "^4.5.8",
    "cross-env": "^10.1.0",
    "effect": "4.0.0-beta.32",
    "eslint": "^10.6.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "fast-check": "^4.8.0",
    "fast-glob": "^3.3.3",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.1.7",
    "jsdom": "^29.1.1",
    "minimatch": "^10.2.5",
    "playwright": "^1.61.1",
    "prettier": "^3.9.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remotion": "4.0.484",
    "rimraf": "^6.1.3",
    "tailwindcss": "4",
    "tinybench": "^6.0.2",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^8.0.0",
    "vite-plus": ">=0.1.24",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "@remotion/*": "4.0.484",
      "remotion": "4.0.484",
      "vitest": ">=4.1.8 <5",
      "@vitest/browser": ">=4.1.8 <5",
      "@vitest/coverage-v8": ">=4.1.8 <5",
      "@vitest/browser-playwright": ">=4.1.8 <5",
      "@vitest/browser-preview": ">=4.1.8 <5",
      "astro": ">=7.0.0 <8",
      "devalue": ">=5.8.1 <6",
      "effect": "4.0.0-beta.32",
      "esbuild": ">=0.28.1 <0.29",
      "fast-uri": ">=3.1.2 <4",
      "js-yaml": ">=4.2.0 <5",
      "loader-utils": ">=2.0.4 <3",
      "markdown-it": ">=14.2.0 <15",
      "picomatch@2": ">=2.3.2 <3",
      "picomatch@4": ">=4.0.4 <5",
      "postcss": ">=8.5.10 <9",
      "smol-toml": ">=1.6.1 <2",
      "undici": ">=7.28.0 <8",
      "uuid": ">=13.0.1 <14",
      "vite@8": ">=8.0.16 <9",
      "ws": ">=8.21.0 <9"
    }
  }
}
