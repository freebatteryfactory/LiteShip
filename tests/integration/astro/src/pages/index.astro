---
/**
 * Minimal page to validate @liteship/astro integration builds without errors.
 * The detect script should be injected into <head> by the integration,
 * and the Satellite shell should serialize its boundary + directive
 * marker for the injected boot scanner.
 */
import Satellite from '@liteship/astro/Satellite';
import { Boundary } from '@liteship/core';

const layout = Boundary.make({
  input: 'viewport.width',
  at: [
    [0, 'compact'],
    [768, 'medium'],
    [1280, 'full'],
  ] as const,
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>liteship integration test</title>
  </head>
  <body>
    <h1>liteship integration test</h1>
    <Satellite boundary={layout}>
      <p>Satellite boundary test element</p>
    </Satellite>
    <div data-liteship-boundary='{"id":"test","input":"viewport.width","thresholds":[0,768,1280],"states":["compact","medium","full"]}'>
      <p>Plain boundary test element</p>
    </div>
  </body>
</html>
