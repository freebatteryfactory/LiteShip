---
import Base from '../layouts/Base.astro';
import { CHAIN_PROGRAM, CHAIN_SSR_PAINT, CHAIN_SELECTED, CHAIN_TOTAL_MS, CHAIN_WINDOWS } from '../server/motion-chain';

// Prerender-friendly: the chain program is composed + lowered once at build time.
// This surface emits no native MotionCompiler CSS, so the `client:motion` floor drives
// its per-window sub-samplers on EVERY browser: the floor is the guarantee and stays
// idle only where native `animation-timeline` CSS actually owns the element.
const program = JSON.stringify(CHAIN_PROGRAM);
const initialState = CHAIN_SSR_PAINT.state;
const seams = CHAIN_WINDOWS.map(([s, e]) => `${Math.round(s * 100)}–${Math.round(e * 100)}%`).join(', ');
---

<Base title="czap showcase -- multi-step motion chain">
  <header class="page-header">
    <h1>Multi-step motion chain</h1>
    <p>
      The card below is driven by ONE authored <code>Reveal.chain</code>: a
      <strong>seq</strong> of a rise <em>followed by</em> a <strong>choice</strong> that
      picks the terminal hue by viewport width. It lowers to a real
      <code>TransitionProgram</code> — distinct windows (<code>{seams}</code>), not the
      old two-endpoint collapse — and <code>client:motion</code> scrubs each window
      through the same floor. Total composed duration:
      <code>{CHAIN_TOTAL_MS}ms</code>; branch selected at build:
      <code>{CHAIN_SELECTED?.branchId ?? 'none'}</code>.
    </p>
  </header>

  <section class="motion-stage">
    <div
      class="chain-card"
      data-czap-boundary="chain-hero"
      data-czap-state={initialState}
      data-czap-motion-program={program}
      client:motion
    >
      <strong>Chain</strong>
      <span>rise, then choose hue — one program</span>
    </div>
  </section>

  <section class="explanation">
    <h2>seq · choice, as a program</h2>
    <ol>
      <li>
        <strong>seq.</strong> The rise (opacity + <code>translateY</code>) occupies the
        first window; its total is <code>Σ</code> of the composed steps.
      </li>
      <li>
        <strong>choice.</strong> Exactly ONE branch executes — the wide-viewport arm
        (teal) — selected by a <code>BranchCondition</code> over
        <code>viewport.width</code>; the unchosen amber arm never writes. The selection
        is recorded as an auditable receipt.
      </li>
      <li>
        <strong>windows.</strong> <code>interpretProgram</code> emits per-window
        sub-samplers; the floor bends each window's own easing over its slice of the
        timeline. Reduced-motion settles straight to the terminal pose.
      </li>
    </ol>
  </section>
</Base>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--czap-primary, #4f46e5);
  }
  .page-header p {
    margin-top: 0.5rem;
    color: var(--czap-muted, #64748b);
    max-width: 44rem;
  }
  code {
    background: var(--czap-border, #e2e8f0);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.85em;
  }
  .motion-stage {
    min-height: 220vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 30vh;
  }
  .chain-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
    padding: 2rem 3rem;
    border-radius: 1rem;
    background: var(--czap-surface, #ffffff);
    border: 2px solid var(--czap-border, #e2e8f0);
    box-shadow: 0 10px 40px color-mix(in srgb, var(--czap-primary, #4f46e5) 20%, transparent);
    position: sticky;
    top: 30vh;
    /* opacity is a real property written inline by the floor each frame; the
       transform + color compose the animated custom properties the chain writes. */
    transform: translateY(var(--czap-chain-hero-y, 48px));
    color: var(--czap-chain-hero-color, var(--czap-text, #1e293b));
  }
  .chain-card strong {
    font-size: 1.5rem;
    font-weight: 800;
    color: currentColor;
  }
  .chain-card span {
    font-size: 0.875rem;
    color: var(--czap-muted, #64748b);
  }
  .explanation { margin-top: 3rem; }
  .explanation h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .explanation ol {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: var(--czap-muted, #64748b);
    font-size: 0.9375rem;
  }
</style>
