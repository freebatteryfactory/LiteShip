---
/**
 * 05 — The AI-safety seam, made visible.
 *
 * LiteShip's AI cast is deliberately TWO steps that cannot be collapsed:
 *
 *   1. validateGraphPatchProposal(graph, patch)  — cast IN: check an untrusted model
 *      proposal against the graph it was cast from.
 *   2. applyValidatedPatch(graph, proposal)      — a SEPARATE, host-authorized step
 *      whose ONLY input is a validation-minted `ValidatedProposal`.
 *
 * `applyValidatedPatch`'s only input is a validation-minted `ValidatedProposal` — its
 * apply token is minted into a module-private registry (no public constructor; a
 * look-alike fails the runtime membership check), so no raw model patch reaches `apply`
 * through this seam. (The graph stays mutable via the lower-level `GraphPatch.apply`
 * kernel — the AI cast just routes through validation by construction.) This page runs
 * four "model proposals" (one valid, three hallucinated) through the same seam and shows
 * that every refusal leaves the graph BYTE-IDENTICAL.
 */
import { AICast, GraphPatch, sealNode, sealGraph } from '@czap/core';
import type { SignalNode, DocumentGraphNode, DocumentGraphEdge, DocumentGraph, CellMeta } from '@czap/core';

const META: CellMeta = {
  created: { wall_ms: 0, counter: 0, node_id: 'example' },
  updated: { wall_ms: 0, counter: 0, node_id: 'example' },
  version: 1,
};

const node = (input: string): SignalNode =>
  sealNode({ _tag: 'DocGraphSignalNode', _version: 1, family: 'signal', id: '', meta: META, input } as unknown as SignalNode);

const graph = (nodes: DocumentGraphNode[], edges: DocumentGraphEdge[] = []): DocumentGraph =>
  sealGraph({ _tag: 'DocumentGraph', _version: 1, meta: META, nodes, edges } as Omit<DocumentGraph, 'id' | 'digest'>);

// The current truth: a content-addressed graph with one signal.
const base = graph([node('scroll.y')]);
const baseSignal = base.nodes[0] as SignalNode;

// The dangling-edge validator returns a structured reason; surface its `message`.
const readable = (err: string): string => {
  try {
    const parsed = JSON.parse(err) as { message?: unknown };
    return typeof parsed.message === 'string' ? parsed.message : err;
  } catch {
    return err;
  }
};

type Row = { title: string; accepted: boolean; detail: string };
const run = (title: string, patch: GraphPatch): Row => {
  const checked = AICast.validateGraphPatchProposal(base, patch);
  if (!checked.ok) {
    return { title, accepted: false, detail: readable(checked.errors[0] ?? 'rejected') };
  }
  // The ONLY consumer of apply is the validation-minted proposal.
  const next = AICast.applyValidatedPatch(base, checked.proposal);
  return { title, accepted: true, detail: `applied — graph re-addressed ${base.id} → ${next.id}` };
};

const rows: Row[] = [
  run('A well-formed proposal that fits the graph', GraphPatch.propose(base, [{ op: 'add', family: 'signal', node: node('viewport.width') }])),
  run('A proposal cast against a DIFFERENT graph', GraphPatch.propose(graph([node('other.graph')]), [{ op: 'add', family: 'signal', node: node('x') }])),
  run('A proposal with an edge to a node that does not exist', GraphPatch.propose(base, [{ op: 'add', edge: { from: base.nodes[0]!.id, to: 'czap:nope' as DocumentGraphEdge['to'], type: 'seq' } }])),
  run('A hallucinated, off-version envelope', { _tag: 'GraphPatch', _version: 999, ops: [] } as unknown as GraphPatch),
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>LiteShip — the AI patch that gets refused</title>
    <style>
      :root { color-scheme: light dark; }
      body { font: 16px/1.6 system-ui, sans-serif; max-width: 46rem; margin: 3rem auto; padding: 0 1.25rem; }
      h1 { font-size: 1.55rem; margin-bottom: .35rem; }
      .lede { opacity: .82; margin-top: 0; }
      code { font-family: ui-monospace, monospace; font-size: .9em; }
      .graph { font-family: ui-monospace, monospace; font-size: .85rem; background: color-mix(in oklab, Canvas 90%, CanvasText); padding: .5rem .75rem; border-radius: .5rem; }
      ul { list-style: none; padding: 0; }
      li { border: 1px solid color-mix(in oklab, Canvas 78%, CanvasText); border-radius: .6rem; padding: .85rem 1rem; margin: .6rem 0; }
      .tag { font-weight: 700; font-size: .72rem; letter-spacing: .05em; padding: .12rem .5rem; border-radius: 1rem; }
      .ok { background: #12833022; color: #1a8a40; }
      .no { background: #b0202022; color: #cc3333; }
      .detail { display: block; margin-top: .4rem; font-family: ui-monospace, monospace; font-size: .8rem; opacity: .85; word-break: break-word; }
      .property { margin-top: 1.5rem; padding: 1rem 1.25rem; border-radius: .6rem; background: #12833014; border: 1px solid #12833040; }
    </style>
  </head>
  <body>
    <h1>The model can suggest. Only a validated proposal can change the truth.</h1>
    <p class="lede">
      LiteShip casts a graph <em>out</em> to an AI as a schema, then casts proposals <em>in</em> through
      <code>validateGraphPatchProposal</code>. <code>applyValidatedPatch</code> accepts only a
      validation-minted witness — an unforgeable token — so no raw model patch can reach it:
      validation is the one way through the seam.
    </p>

    <p>The current truth — a content-addressed graph with one signal:</p>
    <p class="graph">{base.id} · {base.nodes.length} node (<code>{baseSignal.input}</code>)</p>

    <p>Four “model proposals” run through the same seam:</p>
    <ul>
      {
        rows.map((row) => (
          <li>
            <span class={`tag ${row.accepted ? 'ok' : 'no'}`}>{row.accepted ? 'APPLIED' : 'REFUSED'}</span>
            &nbsp;{row.title}
            <span class="detail">{row.detail}</span>
          </li>
        ))
      }
    </ul>

    <p class="property">
      <strong>After every refused proposal, the graph is byte-identical.</strong>
      It still has {base.nodes.length} node, id <code>{base.id}</code>. No hallucinated,
      off-graph, or off-version output ever reached the truth — the seam refused it before
      an apply was even possible.
    </p>
  </body>
</html>
