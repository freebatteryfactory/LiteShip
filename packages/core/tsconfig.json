{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@czap/_spine": ["../_spine/index.d.ts"],
      "@czap/canonical": ["../canonical/src/index.ts"],
      "@czap/error": ["../error/src/index.ts"]
