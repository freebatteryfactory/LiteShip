{
  "name": "liteship",
  "version": "0.12.0",
  "description": "The LiteShip umbrella package: one dependency that installs the whole `@czap/*` adaptive rendering stack — you still import from the individual scopes.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/liteship"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "liteship",
    "czap",
    "adaptive-rendering",
    "framework",
    "meta-package",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/_spine": "workspace:*",
    "@czap/assets": "workspace:*",
    "@czap/astro": "workspace:*",
    "@czap/audit": "workspace:*",
    "@czap/canonical": "workspace:*",
    "@czap/cli": "workspace:*",
    "@czap/cloudflare": "workspace:*",
    "@czap/command": "workspace:*",
    "@czap/compiler": "workspace:*",
    "@czap/core": "workspace:*",
    "@czap/detect": "workspace:*",
    "@czap/edge": "workspace:*",
    "@czap/error": "workspace:*",
    "@czap/gauntlet": "workspace:*",
    "@czap/genui": "workspace:*",
    "@czap/mcp-server": "workspace:*",
    "@czap/quantizer": "workspace:*",
    "@czap/remotion": "workspace:*",
    "@czap/scene": "workspace:*",
    "@czap/stage": "workspace:*",
    "@czap/vite": "workspace:*",
    "@czap/web": "workspace:*",
    "@czap/worker": "workspace:*"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
