{
  "name": "liteship",
  "version": "0.18.0",
  "description": "The LiteShip umbrella package: one dependency that installs the whole `@liteship/*` adaptive rendering stack — you still import from the individual scopes.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/liteship"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "liteship",
    "adaptive-rendering",
    "framework",
    "meta-package",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@liteship/_spine": "workspace:*",
    "@liteship/assets": "workspace:*",
    "@liteship/astro": "workspace:*",
    "@liteship/audit": "workspace:*",
    "@liteship/canonical": "workspace:*",
    "@liteship/cli": "workspace:*",
    "@liteship/cloudflare": "workspace:*",
    "@liteship/command": "workspace:*",
    "@liteship/compiler": "workspace:*",
    "@liteship/core": "workspace:*",
    "@liteship/detect": "workspace:*",
    "@liteship/edge": "workspace:*",
    "@liteship/error": "workspace:*",
    "@liteship/gauntlet": "workspace:*",
    "@liteship/genui": "workspace:*",
    "@liteship/mcp-server": "workspace:*",
    "@liteship/quantizer": "workspace:*",
    "@liteship/remotion": "workspace:*",
    "@liteship/scene": "workspace:*",
    "@liteship/stage": "workspace:*",
    "@liteship/vite": "workspace:*",
    "@liteship/web": "workspace:*",
    "@liteship/worker": "workspace:*"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
