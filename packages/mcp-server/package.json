{
  "name": "@czap/mcp-server",
  "version": "0.12.0",
  "description": "The Model Context Protocol server for LiteShip: exposes the `czap` commands and capsule catalog as MCP tools that AI assistants can call.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/mcp-server"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "czap",
    "liteship",
    "mcp",
    "model-context-protocol",
    "ai-tooling",
    "typescript"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@czap/core": "workspace:*",
    "@czap/error": "workspace:*",
    "@czap/command": "workspace:*",
    "@czap/compiler": "workspace:*",
    "@czap/genui": "workspace:*",
    "fast-glob": "^3.3.3"
  }
}
