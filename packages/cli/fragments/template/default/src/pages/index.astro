---
import Base from '../layouts/Base.astro';
import { layout } from '../adaptive.js';

const plan = layout.plan();
const preview = layout.explain(940);
---

<Base>
  <header class="header">
    <h1>liteship starter</h1>
    <p>Constraint-based adaptive rendering</p>
  </header>

  <main {...layout.attrs()}>
    <article class="liteship-card">
      <h2>Define</h2>
      <p>A boundary turns an input into a few named states.</p>
    </article>
    <article class="liteship-card">
      <h2>Apply</h2>
      <p>layout.attrs() wires the definition onto this element.</p>
    </article>
    <article class="liteship-card">
      <h2>Inspect</h2>
      <p>At 940px, layout.explain() selects <strong>{preview.boundary.state}</strong>.</p>
    </article>
  </main>
</Base>

<style>
  .header {
    text-align: center;
    padding: 2rem 0;
  }

  .header h1 {
    font-size: 2rem;
    font-weight: 700;
  }

  .header p {
    font-size: 1rem;
    opacity: 0.7;
  }

  .liteship-card {
    opacity: 0.85;
    padding: 1rem;
    border: 1px solid currentColor;
    border-radius: 0.5rem;
  }

  .liteship-card h2 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .liteship-card p {
    font-size: 0.875rem;
  }
</style>

<style is:inline set:html={plan.css}></style>
