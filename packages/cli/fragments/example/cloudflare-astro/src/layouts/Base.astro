---
interface Props {
  title?: string;
  boundaryCssHref?: string;
  boundaryCss?: string;
}
const { title = 'LiteShip on Cloudflare', boundaryCssHref, boundaryCss } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    {
      boundaryCssHref ? (
        <link rel="stylesheet" href={boundaryCssHref} />
      ) : boundaryCss ? (
        <style is:inline set:html={boundaryCss}></style>
      ) : null
    }
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
