---
import Base from '../layouts/Base.astro';
import { adaptiveAttrs } from '@liteship/astro';
import { layout } from '../boundaries/layout.boundaries.ts';
---

<Base title="liteship showcase -- worker compositor">
  <header class="page-header">
    <h1>Off-Thread Compositor</h1>
    <p>
      Boundary evaluation and composition run in a Web Worker via SPSC ring
      buffer. The main thread stays free for input handling while the worker
      resolves adaptive state at 60fps.
    </p>
  </header>

  <section class="worker-demo">
    <!-- The panel shows exactly what the worker directive writes back to the DOM:
         the resolved boundary state on data-liteship-state. Resize the window and watch
         it flip off the main thread. (The directive publishes no other DOM telemetry;
         this panel deliberately displays only what is real.) -->
    <div {...adaptiveAttrs({ boundary: layout, directive: 'worker', class: 'worker-container' })}>
      <div class="worker-panel">
        <h2>Worker State</h2>
        <div class="worker-status">
          <div class="worker-status__row">
            <span class="worker-status__label">Boundary</span>
            <span class="worker-status__value" data-liteship-state>pending</span>
          </div>
        </div>
        <p class="worker-note">
          Boundary evaluation runs in the Web Worker over the SPSC ring buffer;
          the value above is written back by the worker directive when the
          resolved state crosses a threshold. The main thread never evaluates.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-header {
    margin-bottom: 2rem;
  }
  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--liteship-primary, #4f46e5);
  }
  .page-header p {
    margin-top: 0.5rem;
    color: var(--liteship-muted, #64748b);
    max-width: 40rem;
  }

  .worker-demo {
    margin: 2rem 0;
  }

  .worker-container {
    border: 1px solid var(--liteship-border, #e2e8f0);
    border-radius: 0.75rem;
    padding: 1.5rem;
    max-width: 32rem;
  }

  .worker-panel h2 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--liteship-primary, #4f46e5);
    margin-bottom: 1rem;
  }

  .worker-status {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .worker-status__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--liteship-border, #e2e8f0);
  }

  .worker-status__label {
    font-size: 0.8125rem;
    color: var(--liteship-muted, #64748b);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  .worker-status__value {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--liteship-text, #1e293b);
    font-variant-numeric: tabular-nums;
  }

  .worker-note {
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--liteship-muted, #64748b);
    line-height: 1.4;
  }
</style>
