{
  "name": "@czap/cli",
  "version": "0.15.0",
  "description": "The `czap` command-line tool for LiteShip: JSON-in, JSON-out verbs built for AI agents, with a human-friendly terminal mode.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "czap",
    "liteship",
    "cli",
    "command-line",
    "json",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "bin": {
    "czap": "./bin/czap.mjs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "bin",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/core": "workspace:*",
    "@czap/command": "workspace:*",
    "@czap/scene": "workspace:*",
    "@czap/assets": "workspace:*",
    "@czap/audit": "workspace:*",
    "@czap/edge": "workspace:*",
    "@czap/gauntlet": "workspace:*",
    "@czap/error": "workspace:*",
    "effect": "catalog:",
    "undici": ">=7.28.0 <8"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
