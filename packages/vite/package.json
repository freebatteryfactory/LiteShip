{
  "name": "@czap/vite",
  "version": "0.5.0",
  "description": "Vite 8 plugin: `@token` / `@theme` / `@style` / `@quantize` CSS transforms + HMR",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/vite"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "czap",
    "vite",
    "vite-plugin",
    "css-transform",
    "hmr",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./html-transform": {
      "types": "./dist/html-transform.d.ts",
      "import": "./dist/html-transform.js",
      "development": "./src/html-transform.ts"
    },
    "./virtual": {
      "types": "./virtual.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "virtual.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/core": "workspace:*",
    "@czap/compiler": "workspace:*",
    "@czap/edge": "workspace:*",
    "@czap/error": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
