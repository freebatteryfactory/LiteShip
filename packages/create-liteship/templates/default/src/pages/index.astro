---
import Base from '../layouts/Base.astro';
import { adaptiveAttrs } from '@liteship/astro';
// Optional LLM catalog path: `pnpm add @liteship/genui`, register a catalog with
// defineComponentCatalog, wire `genuiCatalog` on client:llm / createLLMSession.
// Structured chunks use `{ "_genui": true, "name": "...", "props": { ... } }`.
// The shared layout boundary (mobile / tablet / desktop) drives both
// halves of the adaptive story: adaptiveAttrs() serializes it for the
// client runtime (data-liteship-state updates), and the @quantize block in
// the <style> below resolves the same export to compile static
// @container queries.
import { layout } from '../boundaries/layout.boundaries.js';
---

<Base>
  <header class="header">
    <h1>liteship starter</h1>
    <p>Constraint-based adaptive rendering</p>
  </header>

  <main {...adaptiveAttrs({ boundary: layout, class: 'grid' })}>
    <article class="card">
      <h2>Boundaries</h2>
      <p>Define quantization points where your layout adapts.</p>
    </article>
    <article class="card">
      <h2>Tokens</h2>
      <p>Design values that vary across themes, density, and contrast.</p>
    </article>
    <article class="card">
      <h2>Compile</h2>
      <p>Output to CSS, GLSL, WGSL, ARIA, or AI targets.</p>
    </article>
  </main>
</Base>

<style>
  .header {
    text-align: center;
    padding: var(--liteship-spacing-lg) 0;
  }

  .header h1 {
    font-size: var(--liteship-font-size-lg);
    font-weight: 700;
  }

  .header p {
    font-size: var(--liteship-font-size-md);
    opacity: 0.7;
  }

  .card {
    padding: var(--liteship-spacing-md);
    border: 1px solid currentColor;
    border-radius: 0.5rem;
    opacity: 0.85;
  }

  .card h2 {
    font-size: var(--liteship-font-size-md);
    margin-bottom: var(--liteship-spacing-sm);
  }

  .card p {
    font-size: var(--liteship-font-size-sm);
  }

  @quantize layout {
    mobile {
      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--liteship-spacing-sm);
      }
    }

    tablet {
      .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--liteship-spacing-md);
      }
    }

    desktop {
      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--liteship-spacing-lg);
      }
    }
  }
</style>
