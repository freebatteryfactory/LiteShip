---
interface Props {
  title?: string;
}

const { title = 'liteship starter' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
      }

      html {
        font-family: system-ui, -apple-system, sans-serif;
        color: #172033;
        background: #f7f9fc;
        line-height: 1.6;
      }

      body {
        min-height: 100dvh;
        padding: 1rem;
        container-name: viewport-width;
        container-type: inline-size;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
