{
  "name": "@czap/stage",
  "version": "0.4.0",
  "description": "Stage — the verb layer: cast one DocumentGraph to multiple carriers from one source digest",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/heyoub/LiteShip",
    "directory": "packages/stage"
  },
  "bugs": "https://github.com/heyoub/LiteShip/issues",
  "homepage": "https://github.com/heyoub/LiteShip#readme",
  "keywords": [
    "czap",
    "stage",
    "dual-export",
    "content-addressing",
    "document-graph",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./ffmpeg": {
      "types": "./dist/ffmpeg.d.ts",
      "import": "./dist/ffmpeg.js",
      "development": "./src/ffmpeg.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/astro": "workspace:*",
    "@czap/compiler": "workspace:*",
    "@czap/core": "workspace:*",
    "@czap/error": "workspace:*",
    "@czap/web": "workspace:*"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
