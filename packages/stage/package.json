{
  "name": "@czap/stage",
  "version": "0.13.0",
  "description": "Export one LiteShip document graph to many carriers: prove a single source renders to both a static Astro page and a video, joined under one receipt.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/stage"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "czap",
    "liteship",
    "dual-export",
    "video",
    "static-site",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./ffmpeg": {
      "types": "./dist/ffmpeg.d.ts",
      "import": "./dist/ffmpeg.js",
      "development": "./src/ffmpeg.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/astro": "workspace:*",
    "@czap/compiler": "workspace:*",
    "@czap/core": "workspace:*",
    "@czap/error": "workspace:*",
    "@czap/web": "workspace:*"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
