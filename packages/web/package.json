{
  "name": "@czap/web",
  "version": "0.16.0",
  "description": "The browser runtime for LiteShip: apply CSS, streamed HTML, worker output, and LLM chunks to a live DOM with focus- and scroll-preserving morphing.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/web"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "czap",
    "liteship",
    "dom",
    "browser-runtime",
    "streaming",
    "typescript"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/physical/capture.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./lite": {
      "types": "./dist/lite.d.ts",
      "import": "./dist/lite.js",
      "development": "./src/lite.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/core": "workspace:*",
    "@czap/error": "workspace:*",
    "@czap/genui": "workspace:*",
    "mediabunny": "^1.39.2"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
