  "description": "DOM runtime: Morph, SlotRegistry, SSE client, Physical state, LLM adapter, AudioWorklet",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
