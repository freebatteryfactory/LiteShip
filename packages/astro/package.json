    "./client-directives/svg": {
      "types": "./dist/client-directives/svg.d.ts",
      "import": "./dist/client-directives/svg.js",
      "development": "./src/client-directives/svg.ts"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
