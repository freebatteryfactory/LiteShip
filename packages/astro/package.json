      "types": "./dist/fetch-layer.d.ts",
      "import": "./dist/fetch-layer.js",
      "development": "./src/fetch-layer.ts"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "development": "./src/runtime/index.ts"
    },
    "./runtime/inspector-toolbar-app": {
      "types": "./dist/runtime/inspector-toolbar-app.d.ts",
      "import": "./dist/runtime/inspector-toolbar-app.js",
      "development": "./src/runtime/inspector-toolbar-app.ts"
    },
    "./Satellite": "./src/Satellite.astro",
    "./Satellite.astro": "./src/Satellite.astro"
