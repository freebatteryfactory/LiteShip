{
  "name": "@liteship/astro",
  "version": "0.18.0",
  "description": "The Astro integration for LiteShip: render adaptive UI as islands with the `client:satellite` directive and resolve device tiers on the server for first paint.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/astro"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "liteship",
    "astro",
    "integration",
    "islands",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./client-directives/satellite": {
      "types": "./dist/client-directives/satellite.d.ts",
      "import": "./dist/client-directives/satellite.js",
      "development": "./src/client-directives/satellite.ts"
    },
    "./client-directives/stream": {
      "types": "./dist/client-directives/stream.d.ts",
      "import": "./dist/client-directives/stream.js",
      "development": "./src/client-directives/stream.ts"
    },
    "./client-directives/llm": {
      "types": "./dist/client-directives/llm.d.ts",
      "import": "./dist/client-directives/llm.js",
      "development": "./src/client-directives/llm.ts"
    },
    "./client-directives/worker": {
      "types": "./dist/client-directives/worker.d.ts",
      "import": "./dist/client-directives/worker.js",
      "development": "./src/client-directives/worker.ts"
    },
    "./client-directives/gpu": {
      "types": "./dist/client-directives/gpu.d.ts",
      "import": "./dist/client-directives/gpu.js",
      "development": "./src/client-directives/gpu.ts"
    },
    "./client-directives/wasm": {
      "types": "./dist/client-directives/wasm.d.ts",
      "import": "./dist/client-directives/wasm.js",
      "development": "./src/client-directives/wasm.ts"
    },
    "./client-directives/graph": {
      "types": "./dist/client-directives/graph.d.ts",
      "import": "./dist/client-directives/graph.js",
      "development": "./src/client-directives/graph.ts"
    },
    "./client-directives/motion": {
      "types": "./dist/client-directives/motion.d.ts",
      "import": "./dist/client-directives/motion.js",
      "development": "./src/client-directives/motion.ts"
    },
    "./client-directives/svg": {
      "types": "./dist/client-directives/svg.d.ts",
      "import": "./dist/client-directives/svg.js",
      "development": "./src/client-directives/svg.ts"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "development": "./src/middleware.ts"
    },
    "./middleware-entry": {
      "types": "./dist/middleware-entry.d.ts",
      "import": "./dist/middleware-entry.js",
      "development": "./src/middleware-entry.ts"
    },
    "./fetch-layer": {
      "types": "./dist/fetch-layer.d.ts",
      "import": "./dist/fetch-layer.js",
      "development": "./src/fetch-layer.ts"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "development": "./src/runtime/index.ts"
    },
    "./runtime/inspector-toolbar-app": {
      "types": "./dist/runtime/inspector-toolbar-app.d.ts",
      "import": "./dist/runtime/inspector-toolbar-app.js",
      "development": "./src/runtime/inspector-toolbar-app.ts"
    },
    "./Satellite": "./src/Satellite.astro",
    "./Satellite.astro": "./src/Satellite.astro"
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@liteship/core": "workspace:*",
    "@liteship/canonical": "workspace:*",
    "@liteship/error": "workspace:*",
    "@liteship/vite": "workspace:*",
    "@liteship/detect": "workspace:*",
    "@liteship/edge": "workspace:*",
    "@liteship/genui": "workspace:*",
    "@liteship/scene": "workspace:*",
    "@liteship/web": "workspace:*",
    "@liteship/worker": "workspace:*"
  },
  "peerDependencies": {
    "astro": ">=7.0.0 <8"
  },
  "devDependencies": {
    "astro": "^7.0.0"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
