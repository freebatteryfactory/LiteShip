{
  "name": "@czap/_spine",
  "version": "0.4.1",
  "description": "Type-only declaration spine referenced by published `.d.ts` from `@czap/core` / `@czap/scene`",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/_spine"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "czap",
    "types",
    "type-spine",
    "internal",
    "typescript"
  ],
