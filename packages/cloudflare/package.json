{
  "name": "@czap/cloudflare",
  "version": "0.4.0",
  "description": "Cloudflare Workers siteAdapter: KV boundary cache + Astro middleware glue",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/heyoub/LiteShip",
    "directory": "packages/cloudflare"
  },
  "bugs": "https://github.com/heyoub/LiteShip/issues",
  "homepage": "https://github.com/heyoub/LiteShip#readme",
  "keywords": [
    "czap",
    "cloudflare",
    "workers",
    "workerd",
    "kv",
    "astro",
    "edge",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "development": "./src/testing.ts"
    },
    "./cache-provider": {
      "types": "./dist/cache-provider.d.ts",
      "import": "./cache-provider.mjs",
      "development": "./cache-provider.dev.mjs"
    }
  },
  "files": [
    "cache-provider.mjs",
    "cache-provider.dev.mjs",
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/core": "workspace:*",
    "@czap/edge": "workspace:*",
    "@czap/astro": "workspace:*",
    "@czap/error": "workspace:*"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
