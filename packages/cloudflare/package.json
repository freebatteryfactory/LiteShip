{
  "name": "@czap/cloudflare",
  "version": "0.15.0",
  "description": "Run LiteShip on Cloudflare Workers: a site adapter with a KV-backed edge cache and the Astro middleware glue that caches boundaries at the edge.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/cloudflare"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "czap",
    "liteship",
    "cloudflare",
    "workers",
    "edge",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "development": "./src/testing.ts"
    },
    "./cache-provider": {
      "types": "./dist/cache-provider.d.ts",
      "import": "./cache-provider.mjs",
      "development": "./cache-provider.dev.mjs"
    }
  },
  "files": [
    "cache-provider.mjs",
    "cache-provider.dev.mjs",
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/core": "workspace:*",
    "@czap/edge": "workspace:*",
    "@czap/astro": "workspace:*",
    "@czap/error": "workspace:*"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
