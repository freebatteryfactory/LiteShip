{
  "name": "@czap/command",
  "version": "0.2.1",
  "description": "Shared capsule command registry + dispatcher — one command truth for the CLI and MCP adapters",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/heyoub/LiteShip",
    "directory": "packages/command"
  },
  "bugs": "https://github.com/heyoub/LiteShip/issues",
  "homepage": "https://github.com/heyoub/LiteShip#readme",
  "keywords": [
    "czap",
    "command-registry",
    "dispatcher",
    "cli",
    "mcp",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "import": "./dist/host/index.js",
      "development": "./src/host/index.ts"
    },
    "./host-browser": {
      "types": "./dist/host-browser/index.d.ts",
      "import": "./dist/host-browser/index.js",
      "development": "./src/host-browser/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@czap/core": "workspace:*",
    "@czap/assets": "workspace:*"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
