{
  "name": "@liteship/compiler",
  "version": "0.18.0",
  "description": "Compile one LiteShip boundary definition into many outputs at once — CSS, GLSL, WGSL, ARIA, AI descriptions, and Tailwind — so every target stays in sync.",
  "license": "MIT",
  "author": "Eassa Ayoub <eassa@heyoub.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/freebatteryfactory/LiteShip",
    "directory": "packages/compiler"
  },
  "bugs": "https://github.com/freebatteryfactory/LiteShip/issues",
  "homepage": "https://github.com/freebatteryfactory/LiteShip#readme",
  "keywords": [
    "liteship",
    "css",
    "shaders",
    "aria",
    "compiler",
    "typescript"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/adaptive-lowering.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./parse": {
      "types": "./dist/parse/index.d.ts",
      "import": "./dist/parse/index.js",
      "development": "./src/parse/index.ts"
    },
    "./migrate": {
      "types": "./dist/migrate/index.d.ts",
      "import": "./dist/migrate/index.js",
      "development": "./src/migrate/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@liteship/core": "workspace:*",
    "@liteship/error": "workspace:*"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
