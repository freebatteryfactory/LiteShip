{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@czap/error": ["./packages/error/src/index.ts"],
      "@czap/gauntlet": ["./packages/gauntlet/src/index.ts"],
      "@czap/canonical": ["./packages/canonical/src/index.ts"],
      "@czap/genui": ["./packages/genui/src/index.ts"],
      "@czap/core": ["./packages/core/src/index.ts"],
      "@czap/quantizer": ["./packages/quantizer/src/index.ts"],
      "@czap/compiler": ["./packages/compiler/src/index.ts"],
      "@czap/web/lite": ["./packages/web/src/lite.ts"],
      "@czap/web": ["./packages/web/src/index.ts"],
      "@czap/detect": ["./packages/detect/src/index.ts"],
      "@czap/vite/html-transform": ["./packages/vite/src/html-transform.ts"],
      "@czap/vite": ["./packages/vite/src/index.ts"],
      "@czap/astro/runtime": ["./packages/astro/src/runtime/index.ts"],
      "@czap/astro": ["./packages/astro/src/index.ts"],
      "@czap/remotion": ["./packages/remotion/src/index.ts"],
      "@czap/scene": ["./packages/scene/src/index.ts"],
      "@czap/assets": ["./packages/assets/src/index.ts"],
      "@czap/cli": ["./packages/cli/src/index.ts"],
      "@czap/mcp-server": ["./packages/mcp-server/src/index.ts"],
      "@czap/edge": ["./packages/edge/src/index.ts"],
      "@czap/cloudflare": ["./packages/cloudflare/src/index.ts"],
      "@czap/worker": ["./packages/worker/src/index.ts"],
      "@czap/_spine": ["./packages/_spine"]
    }
  },
  // Scoped to tests that carry compile-time assertions (@ts-expect-error and
  // the helper conformance seams). The broader test tree has accumulated
  // type-errors that are tolerated because tests/ was excluded from
  // typecheck; expanding coverage is follow-up cleanup.
  // The conformance helpers are listed explicitly: their production-surface
  // assertions (MockWebSocket -> WireSocket, MockWorker -> WorkerLike, ...)
  // only bite if this project typechecks them. They import the consumed
  // production modules DIRECTLY (not package indexes) so the typecheck
  // surface stays scoped to the contracts under assertion.
  "include": [
    "tests/unit/track-id.test.ts",
    "tests/unit/spawn-quoting-drift.test.ts",
    // The AI-cast no-bypass proof: its `@ts-expect-error` asserts that raw model
    // output is NOT assignable to `ValidatedProposal` — the load-bearing security
    // property is only enforced if THIS project typechecks the directive.
    "tests/unit/core/ai-cast.test.ts",
    // The DiscreteStateTransition uncompilable-seam proof (#133, Law 16): its
    // `@ts-expect-error` asserts a continuous StateCell / raw SignalNode is NOT
    // assignable to `applyTransition`'s DiscreteStateTransition input — the
    // "widen the replay payload with a signal" fix is only uncompilable if THIS
    // project typechecks the fixture.
    "tests/unit/core/state-transition.test.ts",
    "tests/unit/_spine/beat-contract.test.ts",
    // The worker spine mirror (worker.d.ts) had no drift guard and silently
    // diverged; this pins it via bidirectional spine⇔runtime assignability so a
    // future divergence fails the typecheck (see the file's module doc).
    "tests/unit/_spine/worker-contract.test.ts",
    // The @czap/core spine conformance guard: its type-level assignments
    // (Config.Shape ⇔ runtime, and the CompositeState / VideoConfig / CaptureResult
    // bidirectional pins) only bite if THIS project typechecks them. Listed here so
    // a future divergence between core.d.ts and the @czap/core runtime fails the
    // typecheck rather than living as a dead assertion.
    "tests/unit/spine-conformance.test.ts",
    // The Wave-8.5 TYPE-export surface gate (#156): the mechanism that closes the
    // VALUE-only api-surface snapshot's structural blind spot. Typechecked here so
    // the enumerator's descriptor/roster/reader contracts bite (a drift in the
    // TypeExportSurfaceSnapshot shape fails the typecheck, not just the run).
    "tests/unit/audit/type-export-surface.test.ts",
    // The cure-wave determinism + zero-alloc + perf-claim tests: typechecked here
    // so their type-level contracts (RepoIR / GateVerdictKeyParts folds, the
    // alloc-gate budget import, the gate surface) bite rather than rot.
    "tests/property/verdict-cache-determinism.prop.test.ts",
    "tests/property/repo-ir-determinism.prop.test.ts",
    "tests/property/compositor-zero-alloc.test.ts",
    "tests/property/token-buffer-zero-alloc.test.ts",
    "tests/unit/gauntlet/perf-claim-bench-gate.test.ts",
    "tests/bench/allocation.bench.ts",
    "tests/helpers/mock-event-source.ts",
    "tests/helpers/mock-worker.ts",
    "tests/helpers/mock-dom.ts",
    "tests/helpers/mock-browser.ts",
    "tests/support/structural-schema.ts",
    // The repo-truths single owner (scar S0.4): canonical accessors for the
    // publishable set, references topology, catalog values, workspace version,
    // and package roster. Typechecked here so the accessors' contracts bite.
    "tests/support/repo-truths.ts",
    // The in-workspace pack owner (scar S0.5): the single owner of the
    // `pnpm pack` mechanic shared by the ship tests and the release-pack residue
    // smoke. Typechecked here so PackedManifest / PackInWorkspaceOptions bite.
    "tests/support/pack.ts",
    // The near-miss strictness-mutator derivation (scar S1.1): its predicted
    // issue codes are typed against the kernel `DecodeIssueCode` union, so a
    // misspelled or stale code fails the typecheck rather than the property run.
    "tests/support/near-miss.ts",
    // The Wave 5.5 transition-cage capture substrate: the closed operation-trace
    // vocabulary + the empirical capture harness that drives the current
    // Effect-backed reactive primitives. Typechecked here so the trace/observation
    // contracts and the per-primitive adapters bite (a shape drift fails the
    // typecheck, not just the capture run).
    "tests/support/reactive-trace.ts",
    "tests/support/reactive-capture.ts",
    "tests/unit/core/reactive-capture.test.ts",
    // The Wave 5.5 single-oracle: the fc.commands reference model DERIVED from the
    // CellKernel/Lifetime law tables + its internal-consistency/coverage proof.
    // Typechecked here so the op-vocabulary / Observation / LawCoverage contracts
    // bite (a drift from the projected laws fails the typecheck, not just the run).
    "tests/support/reactive-model.ts",
    "tests/unit/core/reactive-model.test.ts",
    // The Wave 5.5 cross-transport differential oracle (CAGE-A): the reusable
    // bisimulation harness + its seeded conformance property. Typechecked here so
    // the TraceSource / ModelConfig / OracleResult / Difference contracts bite (a
    // model-vs-impl shape drift fails the typecheck, not just the property run),
    // and so Wave 6 can flip the impl side against the SAME typed model surface.
    "tests/support/reactive-oracle.ts",
    "tests/property/reactive-conformance.prop.test.ts"
  ],
  "exclude": ["node_modules", "**/dist/**"]
}
