node_modules/
.pnpm-store/
dist/
*.tsbuildinfo
.DS_Store
.env
.env.*
.idea/
crates/liteship-compute/target/

# Generated release notes — extracted from CHANGELOG at release time, never committed
RELEASE_NOTES_v*.md

# Build artifacts — never in src/
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map

# Example artifacts
examples/remotion-demo/out/
examples/remotion-demo/node_modules/

# Cloudflare / wrangler + miniflare local state (dev cache, KV/cache sqlite,
# deploy config) — per-machine generated state, never tracked.
.wrangler/

# Test artifacts
test-results/
tests/_results/
coverage/
# Ignore benchmarks/ CONTENTS (regenerated run artifacts) but allow the two
# COMMITTED performance CONTRACTS below to be re-included. `benchmarks/*` (not
# `benchmarks/`) is required so git walks the dir and the negations can match —
# a wholesale `benchmarks/` ignore cannot be un-ignored per-file.
benchmarks/*
# …except the two COMMITTED performance CONTRACTS (source of truth, not
# regenerated bench output): the declared-distribution registry (the headline
# law's anchor) and the complexity-map baseline (the regression baseline). The
# performance-contracts gate folds over these committed bytes, so they must be
# tracked — every other benchmarks/ file stays an ignored run artifact.
!benchmarks/distributions.json
!benchmarks/complexity-map.json
# …and the mutation-score baseline (the avionics mutation-as-divergence ratchet
# floor — `liteship check --ir --mutate`'s committed per-file kill-score; the
# mutationDivergenceGate folds it to flag a regression). A committed contract, not
# a regenerated artifact — tracked so the ratchet can only ever rise.
!benchmarks/mutation-score.json
# …and the equivalent-mutant registry (the hand-authored, owner-redlinable,
# content-addressed justifications for the few RUNTIME mutants no test can kill —
# the ONLY honest way to exclude an equivalent mutant). A source-of-truth contract,
# not a regenerated artifact: the engine + the meta-proof test read these committed
# bytes, so it must be present on EVERY CI lane (it was previously ignored, so a
# fresh macos/windows checkout lacked it and the meta-proof's committed-registry
# assertion failed with ENOENT — only the linux lane regenerated it pre-test).
!benchmarks/mutation-equivalents.json
# …and the README bench snapshot: the small, committed distillation of a green CI
# gauntlet run that the README "Latest CI gauntlet run" block renders from
# (`scripts/refresh-bench-snapshot.ts` writes it; `scripts/gen-docs.ts` renders
# it). A committed contract so the front-page numbers ship with the repo, not a
# regenerated run artifact.
!benchmarks/readme-snapshot.json
reports/
.vitest-attachments/
lint-report.json
tests/browser/__screenshots__/
tests/integration/cli/.out-*.mp4
tests/smoke/.out-*.mp4
examples/scenes/*.mp4

# Release artifacts (ADR-0011) — tarballs are intermediate, capsules are
# uploaded to GitHub Releases, neither belong in the working tree.
*.tgz
*.shipcapsule.cbor

# liteship capsule factory scratch (generated MCP manifests, content-addressed cache)
.liteship/

# Local Claude tooling state (per-machine working notes — NEVER in the repo)
.claude/

# IDE workspace files (per-developer)
*.code-workspace

# Gauntlet / shell output logs (large, churn often)
*.log

# Atomic-write tmp orphans from interrupted runs
tests/generated/**/*.tmp
reports/**/*.tmp

# Internal-only docs (kept locally for reference, not for OSS distribution)
docs/superpowers/
docs/sixsigma/
docs/plans/
docs/internal/

# TypeDoc HTML output — the committed API reference is the markdown in docs/api/;
# the HTML build (docs/api-html/) is a heavy, regenerable artifact, never committed.
docs/api-html/

# Stale tsc emit artifacts in scripts/ (tsconfig.scripts.json sets noEmit;
# anything compiled here is leftover from misconfigured local runs)
scripts/**/*.js
scripts/**/*.js.map
scripts/**/*.d.ts
scripts/**/*.d.ts.map

# Astro-generated content/types (regenerated on every astro dev / sync)
**/.astro/

# Scratch scripts from sibling projects (borrow this repo's Playwright install)
.fbf-*.mjs
tests/.liteship-verify-fresh-*/

# Experimental sharded TypeDoc workspace (#136) — never commit
.typedoc-shards/
