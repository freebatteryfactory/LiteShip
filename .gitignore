node_modules/
.pnpm-store/
dist/
*.tsbuildinfo
.DS_Store
.env
.env.*
.idea/
crates/czap-compute/target/

# Generated release notes — extracted from CHANGELOG at release time, never committed
RELEASE_NOTES_v*.md

# Build artifacts — never in src/
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map

# Example artifacts
examples/remotion-demo/out/
examples/remotion-demo/node_modules/

# Cloudflare / wrangler + miniflare local state (dev cache, KV/cache sqlite,
# deploy config) — per-machine generated state, never tracked.
.wrangler/

# Test artifacts
test-results/
tests/_results/
coverage/
benchmarks/
reports/
.vitest-attachments/
lint-report.json
tests/browser/__screenshots__/
tests/integration/cli/.out-*.mp4
tests/smoke/.out-*.mp4

# Release artifacts (ADR-0011) — tarballs are intermediate, capsules are
# uploaded to GitHub Releases, neither belong in the working tree.
*.tgz
*.shipcapsule.cbor

# czap capsule factory scratch (generated MCP manifests, content-addressed cache)
.czap/

# Local Claude tooling state (per-machine working notes — NEVER in the repo)
.claude/

# IDE workspace files (per-developer)
*.code-workspace

# Gauntlet / shell output logs (large, churn often)
*.log

# Atomic-write tmp orphans from interrupted runs
tests/generated/**/*.tmp
reports/**/*.tmp

# Internal-only docs (kept locally for reference, not for OSS distribution)
docs/superpowers/
docs/sixsigma/
docs/plans/
docs/internal/

# TypeDoc HTML output — the committed API reference is the markdown in docs/api/;
# the HTML build (docs/api-html/) is a heavy, regenerable artifact, never committed.
docs/api-html/

# Stale tsc emit artifacts in scripts/ (tsconfig.scripts.json sets noEmit;
# anything compiled here is leftover from misconfigured local runs)
scripts/**/*.js
scripts/**/*.js.map
scripts/**/*.d.ts
scripts/**/*.d.ts.map

# Astro-generated content/types (regenerated on every astro dev / sync)
**/.astro/

# Scratch scripts from sibling projects (borrow this repo's Playwright install)
.fbf-*.mjs
tests/.czap-verify-fresh-*/
